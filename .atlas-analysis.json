  "keyFeatures": [
    "Modern Monaco Editor with syntax highlighting and intelligent code completion",
    "Native Git source control GUI with visual diffs and commit management",
    "Integrated SA-MP/open.mp server manager with live console tracking",
    "Discord Rich Presence integration showing current project and file",
    "Comprehensive encoding support including Turkish (Windows-1254) and 13+ languages",
    "Auto-save functionality with configurable delay",
    "VS Code-inspired interface with dark mode support"
  ],
  "publicApiSurface": [
    "EditorPanel - Main Monaco editor component",
    "Sidebar - File explorer and source control navigation",
    "TabsBar - Multi-file tab management",
    "StatusBar - Editor status and information display",
    "WelcomeScreen - Initial landing page",
    "OutputPanel - Server console and output display",
    "useEditorBridge - IPC communication with Electron main process",
    "useFileOperations - File system operations hook",
    "useSettings - Application settings management",
    "useDiscordRpc - Discord Rich Presence integration",
    "useFolderWatcher - File system watching and auto-refresh",
    "useKeyboardShortcuts - Keyboard shortcut bindings",
    "SettingsModal - Application settings interface",
    "ServerModal - Server management interface",
    "ConfigModal - Server configuration editor",
    "EncodingPicker - Character encoding selector"
